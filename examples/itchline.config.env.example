# Optional: explicit path to butler binary.
# If empty, itchline will try `butler` in PATH, then itch app install path.
BUTLER_BIN=

# Required: itch target slug in USER/GAME format.
ITCH_TARGET=fufroom/fashion-fupa

# Build paths are resolved relative to this config file if not absolute.
ITCH_BUILD_PATH_LINUX=../build/Linux
ITCH_BUILD_PATH_WINDOWS=../build/Windows
ITCH_BUILD_PATH_MAC="../build/Mac/Fashion FUPA.app"

# Itch channels.
ITCH_CHANNEL_LINUX=linux
ITCH_CHANNEL_WINDOWS=windows
ITCH_CHANNEL_MAC=macos

# Optional fixed version label. If empty, itchline uses:
# <project.godot config/version>-YYYYMMDD-HHMMSS
ITCH_USER_VERSION=

# Optional API key for non-interactive upload.
# If empty, butler uses local login/session.
BUTLER_API_KEY=
